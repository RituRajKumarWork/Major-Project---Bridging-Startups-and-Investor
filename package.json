{
    "name": "angel-investor",
    "version": "1.0.0",
    "description": "A dual-sided platform connecting Founders and Investors with AI-powered mentorship and financial projections",
    "private": true,
    "main": "backend/dist/index.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "cd backend && tsx watch src/index.ts",
        "dev:frontend": "cd frontend && next dev",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "cd backend && tsc",
        "build:frontend": "cd frontend && next build",
        "build:clean": "npm run build:clean:backend && npm run build:clean:frontend",
        "build:clean:backend": "cd backend && rm -rf dist && tsc",
        "build:clean:frontend": "cd frontend && rm -rf .next && next build",
        "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
        "start:backend": "cd backend && node dist/index.js",
        "start:frontend": "cd frontend && next start",
        "start:prod": "concurrently \"npm run start:prod:backend\" \"npm run start:prod:frontend\"",
        "start:prod:backend": "cd backend && NODE_ENV=production node dist/index.js",
        "start:prod:frontend": "cd frontend && NODE_ENV=production next start",
        "lint": "npm run lint:frontend",
        "lint:frontend": "cd frontend && eslint",
        "lint:fix": "cd frontend && eslint --fix"
    },
    "keywords": [
        "angel-investor",
        "founders",
        "investors",
        "startup",
        "funding"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/multipart": "^9.3.0",
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "axios": "^1.13.2",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "fastify": "^5.6.2",
        "lucide-react": "^0.562.0",
        "next": "16.1.0",
        "next-themes": "^0.4.6",
        "openai": "^6.15.0",
        "pg": "^8.16.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hook-form": "^7.69.0",
        "react-markdown": "^10.1.0",
        "recharts": "^3.6.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^25.0.3",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "concurrently": "^8.2.2",
        "eslint": "^9",
        "eslint-config-next": "16.1.0",
        "nodemon": "^3.1.11",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3"
    }
}
